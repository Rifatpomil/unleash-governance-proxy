# Unleash Governance Proxy – example environment
# Copy to .env and fill in values.

# Required for JWT verification
JWT_SECRET=your-secret-here

# Database (PostgreSQL recommended for production)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/unleash_governance

# Unleash (required for apply)
UNLEASH_BASE_URL=http://localhost:4242
UNLEASH_API_TOKEN=

# Optional: OpenAI for AI features (summarization, risk explanation, NL query, suggestions)
# OPENAI_API_KEY=sk-...

# Optional: OpenFGA for fine-grained authorization
# OPENFGA_API_URL=
# OPENFGA_STORE_ID=
# OPENFGA_MODEL_ID=

# Optional: rate limit (requests per minute per IP)
# RATE_LIMIT_PER_MINUTE=60
